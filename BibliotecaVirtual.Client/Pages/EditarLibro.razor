@page "/editar-libro/{Id:int}"
@using BibliotecaVirtual.Shared
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                @* Encabezado Estilizado *@
                <div class="card-header p-4 border-0 text-center" style="background-color: var(--ocean-dark); color: white;">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Editar Libro</h3>
                    <p class="mb-0 opacity-75">Actualiza la información técnica y tu reseña personal</p>
                </div>

                <div class="card-body p-4" style="background-color: var(--pearl-white);">
                    @if (libro == null)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border" style="color: var(--ocean-dark);" role="status"></div>
                            <p class="mt-2 text-muted">Cargando datos del libro...</p>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="@libro" OnValidSubmit="Actualizar">
                            <DataAnnotationsValidator />

                            <div class="row g-3">
                                @* Título *@
                                <div class="col-md-12">
                                    <label class="form-label fw-bold" style="color: var(--ocean-dark);">Título del Libro</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-type text-muted"></i></span>
                                        <InputText @bind-Value="libro.Titulo" class="form-control border-start-0 custom-input" />
                                    </div>
                                    <ValidationMessage For="@(() => libro.Titulo)" class="text-danger small" />
                                </div>

                                @* Autor *@
                                <div class="col-md-6">
                                    <label class="form-label fw-bold" style="color: var(--ocean-dark);">Autor</label>
                                    <InputText @bind-Value="libro.Autor" class="form-control custom-input" />
                                    <ValidationMessage For="@(() => libro.Autor)" class="text-danger small" />
                                </div>

                                @* Categoría (Select Dinámico) *@
                                <div class="col-md-6">
                                    <label class="form-label fw-bold" style="color: var(--ocean-dark);">Categoría</label>
                                    <InputSelect @bind-Value="libro.Categoria" class="form-select custom-input">
                                        <option value="">-- Selecciona --</option>
                                        @foreach (var cat in categorias)
                                        {
                                            <option value="@cat.Nombre">@cat.Nombre</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => libro.Categoria)" class="text-danger small" />
                                </div>

                                @* Páginas *@
                                <div class="col-md-6">
                                    <label class="form-label fw-bold" style="color: var(--ocean-dark);">Número de Páginas</label>
                                    <InputNumber @bind-Value="libro.NoPaginas" class="form-control custom-input" />
                                </div>

                                @* Calificación *@
                                <div class="col-md-6">
                                    <label class="form-label fw-bold" style="color: var(--ocean-dark);">Calificación (1-3 ⭐)</label>
                                    <InputNumber @bind-Value="libro.Calificación" class="form-control custom-input" min="1" max="3" />
                                </div>

                                @* Estado de lectura *@
                                <div class="col-md-12 mt-2">
                                    <div class="form-check form-switch custom-switch">
                                        <InputCheckbox @bind-Value="libro.Leido" class="form-check-input" id="checkLeidoEdit" />
                                        <label class="form-check-label fw-bold" for="checkLeidoEdit" style="color: var(--ocean-dark);">¿Ya lo leíste?</label>
                                    </div>
                                </div>

                                @* Reseña *@
                                <div class="col-md-12">
                                    <label class="form-label fw-bold" style="color: var(--ocean-dark);">Reseña o Comentario</label>
                                    <InputTextArea @bind-Value="libro.Reseña" class="form-control custom-input" rows="3" placeholder="Escribe tus impresiones..." />
                                </div>

                                @* Nueva Portada *@
                                <div class="col-md-12">
                                    <label class="form-label fw-bold" style="color: var(--ocean-dark);">Actualizar Portada (Opcional)</label>
                                    <InputFile OnChange="OnFileChange" class="form-control custom-input" accept="image/*" />
                                    <div class="form-text mt-1 text-muted"><i class="bi bi-info-circle me-1"></i>Deja vacío para conservar la imagen actual.</div>
                                </div>
                            </div>

                            @* Acciones *@
                            <div class="d-flex justify-content-between align-items-center mt-5">
                                <button type="button" class="btn btn-cancelar px-4 rounded-pill" @onclick="Regresar">
                                    Cancelar
                                </button>
                                <button type="submit" class="btn btn-guardar px-5 rounded-pill shadow-sm">
                                    <i class="bi bi-arrow-repeat me-2"></i>Actualizar Cambios
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private Book? libro;
    private List<Categoria> categorias = new List<Categoria>();
    private IBrowserFile? nuevaPortada;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Carga paralela de categorías y datos del libro
            var catTask = Http.GetFromJsonAsync<List<Categoria>>("api/Categorias");
            var bookTask = Http.GetFromJsonAsync<Book>($"api/Books/{Id}");
            
            categorias = await catTask ?? new List<Categoria>();
            libro = await bookTask;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
        }
    }

    private void OnFileChange(InputFileChangeEventArgs e) => nuevaPortada = e.File;

    private async Task Actualizar()
    {
        if (libro == null) return;

        using var content = new MultipartFormDataContent();
        
        // Mantenemos todos los campos originales para el envío
        content.Add(new StringContent(libro.Id.ToString()), "Id");
        content.Add(new StringContent(libro.Titulo ?? string.Empty), "Titulo");
        content.Add(new StringContent(libro.Autor ?? string.Empty), "Autor");
        content.Add(new StringContent(libro.Reseña ?? string.Empty), "Reseña");
        content.Add(new StringContent(libro.NoPaginas.ToString()), "NoPaginas");
        content.Add(new StringContent(libro.Categoria ?? string.Empty), "Categoria");
        content.Add(new StringContent(libro.Calificación.ToString()), "Calificación");
        content.Add(new StringContent(libro.Leido.ToString().ToLower()), "Leido");

        if (nuevaPortada != null)
        {
            var fileContent = new StreamContent(nuevaPortada.OpenReadStream(1024 * 1024 * 5));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(nuevaPortada.ContentType);
            content.Add(fileContent, "file", nuevaPortada.Name);
        }

        var response = await Http.PutAsync($"api/Books/{Id}", content);
        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/libros");
        }
    }

    private void Regresar() => Nav.NavigateTo("/libros");
}